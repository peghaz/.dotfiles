{
    "workbench.startupEditor": "newUntitledFile",
    "editor.maxTokenizationLineLength": 50000,
    "[dart]": {
        "editor.formatOnSave": true,
        "editor.rulers": [
            80
        ],
        "editor.selectionHighlight": false,
        "editor.suggest.snippetsPreventQuickSuggestions": false,
        "editor.suggestSelection": "first",
        "editor.tabCompletion": "onlySnippets",
        "editor.wordBasedSuggestions": "off"
    },
    "editor.codeLens": true,
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "[javascript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features",
        "editor.autoClosingBrackets": "always"
    },
    "explorer.confirmDelete": false,
    "debug.onTaskErrors": "showErrors",
    "javascript.updateImportsOnFileMove.enabled": "always",
    "explorer.confirmDragAndDrop": false,
    "files.watcherExclude": {
        "**/.bloop": true,
        "**/.metals": true,
        "**/.ammonite": true,
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true,
        "**/node_modules/**": true,
        "**/tmp/**": true,
        "**/dist/**": true
    },
    "workbench.preferredDarkColorTheme": "GitHub Dark Default",
    "workbench.preferredLightColorTheme": "GitHub Light Default",
    "workbench.preferredHighContrastColorTheme": "GitHub Dark High Contrast",
    "workbench.preferredHighContrastLightColorTheme": "GitHub Light High Contrast",
    "python.showStartPage": false,
    "autopep8.args": [
        "--max-line-length=200",
        "--ignore=E402"
    ],
    "vim.highlightedyank.duration": 200,
    "vim.highlightedyank.color": "rgba(250, 240, 170, 0.5)",
    "vim.useSystemClipboard": false,
    "vim.handleKeys": {
        "<C-p>": false,
        "<C-b>": false,
        "<C-w>": false,
        "<C-k>": false,
        "<C-f>": false,
        "<C-y>": false,
        "<C-d>": false
    },
    "vim.leader": " ",
    "interactiveWindow.alwaysScrollOnNewCell": false,
    "terminal.integrated.shellIntegration.enabled": true,
    "terminal.integrated.shellIntegration.decorationsEnabled": "never",
    "editor.suggestSelection": "first",
    "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
    "terminal.integrated.fontSize": 16,
    "jupyter.askForKernelRestart": false,
    "markdown.preview.fontSize": 18,
    "[python]": {
        "editor.autoClosingBrackets": "always",
        "editor.formatOnType": true,
        "editor.defaultFormatter": "ms-python.autopep8"
    },
    "vsicons.dontShowNewVersionMessage": true,
    "files.exclude": {
        "**/.vs": true,
        "**/env": true,
        "**/tmp/**": true,
        "**/node_modules/**": true,
        "**/.git/objects/**": true
    },
    "typescript.updateImportsOnFileMove.enabled": "always",
    "redhat.telemetry.enabled": true,
    "cmake.configureOnOpen": false,
    "workbench.editorAssociations": {
        "*.ipynb": "jupyter-notebook",
        "*.txt": "default"
    },
    "search.collapseResults": "alwaysCollapse",
    "search.exclude": {
        "**/node_modules/**": true,
        "**/dist/**": true,
        "**/tmp/**": true,
        "**/.git/objects/**": true,
        "**/.git/subtree-cache/**": true
    },
    "jupyter.jupyterServerType": "local",
    "editor.largeFileOptimizations": false,
    "files.maxMemoryForLargeFilesMB": 4,
    "window.titleBarStyle": "custom",
    "jupyter.alwaysTrustNotebooks": true,
    "files.associations": {
        "*.js": "javascript",
        "*.rmd": "markdown",
        "p": "OpenFOAM",
        "U": "OpenFOAM",
        "transportProperties": "OpenFOAM",
        "controlDict": "OpenFOAM",
        "foamDataToFluentDict": "OpenFOAM",
        "fvSchemes": "OpenFOAM",
        "fvSolution": "OpenFOAM",
        "*.msh": "OpenFOAM",
        "physicalProperties": "OpenFOAM",
        "phi": "OpenFOAM",
        "faces": "OpenFOAM",
        "D": "OpenFOAM",
        "T": "OpenFOAM",
        "blockMeshDict": "OpenFOAM",
        "graphUniform": "OpenFOAM",
        "singleGraph": "OpenFOAM",
        "mechanicalProperties": "OpenFOAM",
        "thermalProperties": "OpenFOAM",
        "cellZones": "OpenFOAM",
        "boundary": "OpenFOAM",
        "faceZones": "OpenFOAM",
        "points": "OpenFOAM",
        "owner": "OpenFOAM",
        "pointZones": "OpenFOAM",
        "neighbour": "OpenFOAM",
        "nut": "OpenFOAM",
        "nutkWallFunction": "OpenFOAM",
        "nutUSpaldingWallFunction": "OpenFOAM",
        "nutkLowReWallFunction": "OpenFOAM",
        "nuTilda": "OpenFOAM",
        "turbulenceProperties": "OpenFOAM",
        "k": "OpenFOAM",
        "decomposeParDict": "OpenFOAM",
        "sample": "OpenFOAM"
    },
    "git.enableSmartCommit": true,
    "notebook.cellToolbarLocation": {
        "default": "right",
        "jupyter-notebook": "left"
    },
    "notebook.markup.fontSize": 14,
    "notebook.output.fontSize": 12,
    "editor.autoClosingQuotes": "always",
    "[typescriptreact]": {
        "editor.autoClosingBrackets": "always",
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[javascriptreact]": {
        "editor.autoClosingBrackets": "always"
    },
    "[typescript]": {
        "editor.autoClosingBrackets": "always",
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "security.workspace.trust.untrustedFiles": "open",
    "editor.minimap.enabled": false,
    "terminal.integrated.inheritEnv": true,
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "remote.SSH.remotePlatform": {
        "taeyeon.d2.comp.nus.edu.sg": "linux",
        "taeyeon": "linux"
    },
    "debug.terminal.clearBeforeReusing": true,
    "terminal.integrated.defaultProfile.linux": "zsh",
    "python.defaultInterpreterPath": "C:\\Users\\Mehdi\\miniconda3\\python.exe",
    "editor.accessibilitySupport": "off",
    "terminal.integrated.commandsToSkipShell": [
        "language-julia.interrupt",
        "matlab.interrupt"
    ],
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "source": "PowerShell",
            "icon": "terminal-powershell"
        },
        "Command Prompt": {
            "path": [
                "${env:windir}\\Sysnative\\cmd.exe",
                "${env:windir}\\System32\\cmd.exe"
            ],
            "args": [],
            "icon": "terminal-cmd"
        },
        "Git Bash": {
            "source": "Git Bash"
        },
        "Ubuntu-20.04 (WSL)": {
            "path": "C:\\WINDOWS\\System32\\wsl.exe",
            "args": [
                "-d",
                "Ubuntu-20.04"
            ]
        },
        "Windows PowerShell": {
            "path": "C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"
        }
    },
    "git.openRepositoryInParentFolders": "always",
    "cmake.additionalKits": [],
    "C_Cpp.vcpkg.enabled": false,
    "editor.inlineSuggest.enabled": true,
    "notebook.output.textLineLimit": 10,
    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": true,
        "scminput": false,
        "latex": false,
        "scala": false
    },
    "terminal.integrated.fontFamily": "Hack Nerd Font",
    "cmake.options.statusBarVisibility": "compact",
    "editor.lineNumbers": "relative",
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "editor.fontWeight": "200",
    "remote.autoForwardPortsSource": "hybrid",
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "editor.fontFamily": "'Hack Nerd Font'",
    "[scss]": {
        "editor.defaultFormatter": "vscode.css-language-features"
    },
    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": [
                "<leader>",
                "w"
            ],
            "commands": [
                "workbench.action.files.saveAll"
            ]
        },
        {
            "before": [
                "<leader>",
                "q"
            ],
            "commands": [
                "workbench.action.closeActiveEditor"
            ]
        }
    ],
    "github.copilot.editor.enableAutoCompletions": true,
    "cmake.pinnedCommands": [
        "workbench.action.tasks.configureTaskRunner",
        "workbench.action.tasks.runTask"
    ],
    "workbench.colorTheme": "Spinel",
    "window.autoDetectColorScheme": true,
    "workbench.iconTheme": "vscode-icons",
    "jupyter.disableJupyterAutoStart": true,
    "python.REPL.sendToNativeREPL": false
}